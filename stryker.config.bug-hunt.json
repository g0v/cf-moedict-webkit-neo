{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Bug-hunting Stryker run on a single file. No break threshold; just observes survivors so we can triage them as latent bugs vs. equivalent mutants.",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.unit.config.ts"
  },
  "mutate": [
    "src/utils/xref-switch-utils.ts"
  ],
  "reporters": ["progress", "clear-text", "html", "json"],
  "coverageAnalysis": "all",
  "concurrency": 4,
  "timeoutMS": 15000
}
