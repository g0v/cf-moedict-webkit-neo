{
	"name": "cf-moedict-webkit-neo",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"generate-c-index": "node commands/generateCIndex.js",
		"predev": "npm run build-search-index && npm run build-pinyin-lookup",
		"prebuild": "npm run build-search-index && npm run build-pinyin-lookup",
		"build-search-index": "node scripts/build-search-index.mjs",
		"build-pinyin-lookup": "node scripts/build-pinyin-lookup.mjs",
		"dev": "vite",
		"dev:remote": "VITE_CLOUDFLARE_REMOTE_DEV=1 vite",
		"build": "tsc -b && vite build",
		"lint": "eslint .",
		"typecheck": "tsc -b --noEmit",
		"smoke:sub-routes": "node scripts/smoke-sub-routes.mjs",
		"seed:fixtures": "node tests/seed-fixtures.mjs",
		"test": "npm run test:unit && npm run test:integration && npm run test:e2e",
		"test:unit": "vitest run --config vitest.unit.config.ts",
		"test:unit:watch": "vitest --config vitest.unit.config.ts",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"test:e2e": "playwright test --project=chromium",
		"test:e2e:update": "playwright test --update-snapshots",
		"test:e2e:visual": "playwright test --project=visual",
		"test:e2e:visual:update": "playwright test --project=visual --update-snapshots",
		"preview": "npm run build && npx wrangler dev",
		"deploy": "npm run build && npx wrangler deploy",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@cf-wasm/resvg": "^0.1.24",
		"fuse.js": "^7.1.0",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"react-router-dom": "^7.13.1"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.25.5",
		"@eslint/js": "^9.33.0",
		"@playwright/test": "^1.59.1",
		"@types/node": "^24.7.2",
		"@types/react": "^19.1.10",
		"@types/react-dom": "^19.1.7",
		"@vitejs/plugin-react": "^5.0.0",
		"@vitest/coverage-v8": "^4.1.4",
		"eslint": "^9.33.0",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.20",
		"globals": "^16.3.0",
		"happy-dom": "^20.9.0",
		"miniflare": "^4.20260415.0",
		"tsx": "^4.21.0",
		"typescript": "~5.8.3",
		"typescript-eslint": "^8.39.1",
		"vite": "^7.3.2",
		"vitest": "^4.1.4",
		"wrangler": "^4.68.1"
	},
	"overrides": {
		"undici": "^7.24.0"
	}
}
